# App base URL used by frontend and callbacks
NEXT_PUBLIC_APP_URL=

# Session signing secret
SESSION_SECRET=

# Auth0 settings
AUTH0_SECRET=
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Google Apps Script Web App endpoint
GAS_WEBAPP_URL=

# Google service account email (if used for integrations)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Google private key (multiline key; keep secret in real env)
GOOGLE_PRIVATE_KEY=

# Google Sheets ID for MVP tracking data
GOOGLE_SHEETS_ID=

# Telegram bot token for notifications
TELEGRAM_BOT_TOKEN=

# Telegram chat ID target for alerts/updates
TELEGRAM_CHAT_ID=

# Optional feature flag bundle identifier
FEATURE_FLAGS_VERSION=
